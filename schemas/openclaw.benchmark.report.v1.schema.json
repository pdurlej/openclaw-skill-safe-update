{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pdurlej/openclaw-skill-safe-update/schemas/openclaw.benchmark.report.v1.schema.json",
  "title": "OpenClaw Benchmark Aggregate Comparison Report",
  "description": "Evaluation-only aggregate comparison report emitted by the benchmark runner (issue #22). It compares the per-arm scorecards over the same frozen corpus for one (model_family, role) worker. The report never affects the canonical verdict; canonical_status_effect is always none. The sole worker-value metric remains incremental_recall for the advisory arm; baseline and shadow_impact are reported through their deterministic-arm recall analogues (baseline_coverage and shadow_parity). Agreement between arms is never confidence.",
  "type": "object",
  "required": [
    "schema",
    "effect",
    "runtime_effect",
    "external_effect",
    "external_write_effect",
    "production_apply_allowed",
    "operator_approval",
    "authoritative",
    "canonical_status_effect",
    "corpus_digest",
    "manifest_fixture_count",
    "run",
    "scorecards",
    "comparison",
    "pairwise_error_correlation",
    "budgets",
    "threshold_results"
  ],
  "properties": {
    "schema": {
      "const": "openclaw.benchmark.report.v1"
    },
    "effect": {
      "const": "benchmark_evaluation_only"
    },
    "runtime_effect": {
      "const": "none"
    },
    "external_effect": {
      "const": "none"
    },
    "external_write_effect": {
      "const": "none"
    },
    "production_apply_allowed": {
      "const": false
    },
    "operator_approval": {
      "const": false
    },
    "authoritative": {
      "const": false
    },
    "canonical_status_effect": {
      "const": "none"
    },
    "corpus_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "manifest_fixture_count": {
      "type": "integer",
      "minimum": 12
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "scorecards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/scorecardRef"
      }
    },
    "comparison": {
      "type": "object",
      "description": "Per-arm side-by-side comparison. The value axis is incremental_recall_basis_points (advisory), baseline_coverage (baseline), and shadow_parity (shadow_impact); every other field is a diagnostic.",
      "required": [
        "baseline",
        "shadow_impact",
        "advisory"
      ],
      "properties": {
        "baseline": {
          "$ref": "#/$defs/armComparison"
        },
        "shadow_impact": {
          "$ref": "#/$defs/armComparison"
        },
        "advisory": {
          "$ref": "#/$defs/armComparison"
        }
      },
      "additionalProperties": false
    },
    "pairwise_error_correlation": {
      "type": "object",
      "description": "Cross-arm error correlation diagnostics. Each value is the share of fixtures where both arms erred over the union of fixtures where at least one erred, in basis points. Null when one of the arms has no scorecard. This is a diagnostic and never a worker-value metric; agreement between arms is never confidence.",
      "required": [
        "baseline_shadow_impact",
        "baseline_advisory",
        "shadow_impact_advisory"
      ],
      "properties": {
        "baseline_shadow_impact": {
          "$ref": "#/$defs/correlationValue"
        },
        "baseline_advisory": {
          "$ref": "#/$defs/correlationValue"
        },
        "shadow_impact_advisory": {
          "$ref": "#/$defs/correlationValue"
        }
      },
      "additionalProperties": false
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "threshold_results": {
      "type": "object",
      "description": "Frozen threshold gates copied verbatim from the manifest; never rewritten by the runner.",
      "required": [
        "min_incremental_recall",
        "max_false_unaffected",
        "min_shadow_parity",
        "max_unjustified_not_available"
      ],
      "properties": {
        "min_incremental_recall": {
          "$ref": "#/$defs/thresholdGate"
        },
        "max_false_unaffected": {
          "$ref": "#/$defs/thresholdGate"
        },
        "min_shadow_parity": {
          "$ref": "#/$defs/thresholdGate"
        },
        "max_unjustified_not_available": {
          "$ref": "#/$defs/thresholdGate"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "armEnum": {
      "enum": [
        "baseline",
        "shadow_impact",
        "advisory"
      ]
    },
    "correlationValue": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "maximum": 10000
    },
    "worker": {
      "type": "object",
      "description": "The (model_family, role) pair this report covers. Both axes are required and never collapsed.",
      "required": [
        "id",
        "model_family",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "model_family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      },
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "description": "Volatile run envelope. None of these fields enter the canonical scorecard digests or the per-fixture evidence references.",
      "required": [
        "run_id",
        "generated_at",
        "worker",
        "arms",
        "advisory_adapter"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "worker": {
          "$ref": "#/$defs/worker"
        },
        "arms": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/armEnum"
          }
        },
        "advisory_adapter": {
          "type": "string",
          "description": "Identifier of the configured advisory adapter, or 'not_configured' when no adapter was supplied. A configured adapter that returned not_available for every fixture is still named here."
        }
      },
      "additionalProperties": false
    },
    "scorecardRef": {
      "type": "object",
      "description": "Pointer to a per-arm scorecard plus its canonical digest and value metric. The canonical_scorecard_digest excludes all volatile envelope fields so deterministic arms are reproducible across re-runs.",
      "required": [
        "arm",
        "path",
        "canonical_scorecard_digest",
        "incremental_recall_basis_points",
        "threshold_passed"
      ],
      "properties": {
        "arm": {
          "$ref": "#/$defs/armEnum"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "canonical_scorecard_digest": {
          "$ref": "#/$defs/digest"
        },
        "incremental_recall_basis_points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "threshold_passed": {
          "type": "boolean",
          "description": "True when this arm satisfied every threshold gate that applies to it. For the optional advisory arm with no scorecard (all not_available), this reflects the threshold results actually computed."
        }
      },
      "additionalProperties": false
    },
    "armComparison": {
      "type": "object",
      "description": "Side-by-side value and diagnostic summary for one arm. The value axis is incremental_recall_basis_points (the field is named uniformly across arms; for the baseline arm it is baseline_coverage and for the shadow_impact arm it is shadow_parity).",
      "required": [
        "present",
        "incremental_recall_basis_points",
        "missed_regressions_total",
        "unique_true_positives_total",
        "false_blocks_total",
        "false_unaffected_count",
        "controlled_failure_count",
        "honest_not_available_count",
        "unjustified_not_available_count",
        "raw_volume",
        "duplicate_finding_rate_basis_points",
        "valid_evidence_reference_rate_basis_points",
        "hostile_input_robustness_basis_points",
        "wall_clock_seconds_total",
        "review_minutes_total",
        "compute_tokens_total",
        "canonical_scorecard_digest"
      ],
      "properties": {
        "present": {
          "type": "boolean",
          "description": "False when no scorecard exists for this arm (e.g. the optional advisory arm was not run)."
        },
        "incremental_recall_basis_points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "missed_regressions_total": {
          "type": "integer",
          "minimum": 0
        },
        "unique_true_positives_total": {
          "type": "integer",
          "minimum": 0
        },
        "false_blocks_total": {
          "type": "integer",
          "minimum": 0
        },
        "false_unaffected_count": {
          "type": "integer",
          "minimum": 0
        },
        "controlled_failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "honest_not_available_count": {
          "type": "integer",
          "minimum": 0
        },
        "unjustified_not_available_count": {
          "type": "integer",
          "minimum": 0
        },
        "raw_volume": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_finding_rate_basis_points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "valid_evidence_reference_rate_basis_points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "hostile_input_robustness_basis_points": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "wall_clock_seconds_total": {
          "type": "number",
          "minimum": 0
        },
        "review_minutes_total": {
          "type": "number",
          "minimum": 0
        },
        "compute_tokens_total": {
          "type": "integer",
          "minimum": 0
        },
        "canonical_scorecard_digest": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "Canonical digest of the per-arm scorecard, or null when no scorecard exists."
        }
      },
      "additionalProperties": false
    },
    "budgets": {
      "type": "object",
      "description": "Frozen budgets copied verbatim from the manifest, plus observed overflow flags. Overflow is recorded but never relaxes a threshold.",
      "required": [
        "wall_clock_seconds_per_fixture",
        "wall_clock_seconds_total",
        "compute_tokens_per_fixture",
        "review_minutes_total",
        "overflow"
      ],
      "properties": {
        "wall_clock_seconds_per_fixture": {
          "type": "integer",
          "minimum": 1
        },
        "wall_clock_seconds_total": {
          "type": "integer",
          "minimum": 1
        },
        "compute_tokens_per_fixture": {
          "type": "integer",
          "minimum": 1
        },
        "review_minutes_total": {
          "type": "integer",
          "minimum": 1
        },
        "overflow": {
          "type": "object",
          "required": [
            "wall_clock_seconds_per_fixture",
            "wall_clock_seconds_total",
            "compute_tokens_per_fixture",
            "review_minutes_total"
          ],
          "properties": {
            "wall_clock_seconds_per_fixture": {
              "type": "boolean"
            },
            "wall_clock_seconds_total": {
              "type": "boolean"
            },
            "compute_tokens_per_fixture": {
              "type": "boolean"
            },
            "review_minutes_total": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "thresholdGate": {
      "type": "object",
      "required": [
        "threshold",
        "observed",
        "passed"
      ],
      "properties": {
        "threshold": {
          "type": "integer",
          "minimum": 0
        },
        "observed": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
