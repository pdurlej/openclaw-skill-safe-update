{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pdurlej/openclaw-skill-safe-update/schemas/openclaw.safe_update.shadow_runs_index.v1.schema.json",
  "title": "OpenClaw Safe Update Shadow Runs Index",
  "type": "object",
  "required": ["schema", "effect", "runtime_effect", "external_effect", "external_write_effect", "authoritative", "canonical_status_effect", "decision", "selective_omission_enabled", "future_selective_rfc_required", "human_risk_acceptance_can_upgrade", "collection", "thresholds", "observed", "completion", "blockers", "runs"],
  "properties": {
    "schema": {"const": "openclaw.safe_update.shadow_runs_index.v1"},
    "effect": {"const": "evaluation_only"},
    "runtime_effect": {"const": "none"},
    "external_effect": {"const": "none"},
    "external_write_effect": {"const": "none"},
    "authoritative": {"const": false},
    "canonical_status_effect": {"const": "none"},
    "decision": {"const": "retain_additive_baseline"},
    "selective_omission_enabled": {"const": false},
    "future_selective_rfc_required": {"const": true},
    "human_risk_acceptance_can_upgrade": {"const": false},
    "collection": {
      "type": "object",
      "required": ["state", "budget_days", "max_field_rehearsals", "budget_exhausted", "stop_reason"],
      "properties": {
        "state": {"const": "closed_early_conservative"},
        "budget_days": {"const": 90},
        "max_field_rehearsals": {"const": 10},
        "budget_exhausted": {"const": false},
        "stop_reason": {"const": "positive_minimum_not_sought_in_v1.3"}
      },
      "additionalProperties": false
    },
    "thresholds": {"$ref": "#/$defs/counts"},
    "observed": {"$ref": "#/$defs/counts"},
    "completion": {
      "type": "object",
      "required": ["fixtures_percent", "field_rehearsals_percent", "candidate_roots_percent", "positive_gate_met"],
      "properties": {
        "fixtures_percent": {"type": "integer", "minimum": 0, "maximum": 100},
        "field_rehearsals_percent": {"type": "integer", "minimum": 0, "maximum": 100},
        "candidate_roots_percent": {"type": "integer", "minimum": 0, "maximum": 100},
        "positive_gate_met": {"const": false}
      },
      "additionalProperties": false
    },
    "blockers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["field_rehearsals_below_minimum", "distinct_candidate_roots_below_minimum", "unique_finding_evidence_incomplete"]
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/run"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nullableDigest": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
    "counts": {
      "type": "object",
      "required": ["labeled_fixtures", "field_rehearsals", "distinct_candidate_roots", "unexplained_false_greens", "omitted_failing_or_risk_revealing_checks", "unique_findings_with_complete_evidence"],
      "properties": {
        "labeled_fixtures": {"type": "integer", "minimum": 0},
        "field_rehearsals": {"type": "integer", "minimum": 0},
        "distinct_candidate_roots": {"type": "integer", "minimum": 0},
        "unexplained_false_greens": {"type": "integer", "minimum": 0},
        "omitted_failing_or_risk_revealing_checks": {"type": "integer", "minimum": 0},
        "unique_findings_with_complete_evidence": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "required": ["id", "stratum", "status", "candidate_root", "corpus_digest", "run_digest", "evidence_digests", "fixture_count", "hypothetical_omissions", "unexplained_false_greens", "omitted_failing_or_risk_revealing_checks", "evidence_links"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "stratum": {"enum": ["fixture", "field"]},
        "status": {"enum": ["completed", "blocked", "not_available"]},
        "candidate_root": {"$ref": "#/$defs/nullableDigest"},
        "corpus_digest": {"$ref": "#/$defs/nullableDigest"},
        "run_digest": {"$ref": "#/$defs/digest"},
        "evidence_digests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/digest"}
        },
        "fixture_count": {"type": "integer", "minimum": 0},
        "hypothetical_omissions": {"type": "integer", "minimum": 0},
        "unexplained_false_greens": {"type": "integer", "minimum": 0},
        "omitted_failing_or_risk_revealing_checks": {"type": "integer", "minimum": 0},
        "evidence_links": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    }
  }
}
