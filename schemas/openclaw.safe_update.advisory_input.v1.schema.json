{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pdurlej/openclaw-skill-safe-update/schemas/openclaw.safe_update.advisory_input.v1.schema.json",
  "title": "OpenClaw Safe Update Public-Safe Advisory Input",
  "type": "object",
  "required": [
    "schema",
    "effect",
    "runtime_effect",
    "external_effect",
    "external_write_effect",
    "production_apply_allowed",
    "operator_approval",
    "authoritative",
    "input_digest",
    "content"
  ],
  "properties": {
    "schema": {
      "const": "openclaw.safe_update.advisory_input.v1"
    },
    "effect": {
      "const": "public_safe_openclaw_advisory_boundary"
    },
    "runtime_effect": {
      "const": "none"
    },
    "external_effect": {
      "const": "none"
    },
    "external_write_effect": {
      "const": "none"
    },
    "production_apply_allowed": {
      "const": false
    },
    "operator_approval": {
      "const": false
    },
    "authoritative": {
      "const": false
    },
    "input_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "content": {
      "$ref": "#/$defs/content"
    }
  },
  "$defs": {
    "content": {
      "type": "object",
      "required": [
        "candidate_root",
        "scope",
        "source_digests",
        "baseline_checks",
        "facts",
        "limits"
      ],
      "properties": {
        "candidate_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "source_digests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sourceDigest"
          }
        },
        "baseline_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/baselineCheck"
          }
        },
        "facts": {
          "$ref": "#/$defs/facts"
        },
        "limits": {
          "$ref": "#/$defs/limits"
        }
      },
      "additionalProperties": false
    },
    "sourceDigest": {
      "type": "object",
      "required": [
        "id",
        "sha256"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "baselineCheck": {
      "type": "object",
      "required": [
        "id",
        "description",
        "definition_digest",
        "evidence_digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "description": {
          "type": "string"
        },
        "definition_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "evidence_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "facts": {
      "type": "object",
      "required": [
        "packages",
        "affected_components",
        "affected_capabilities",
        "affected_contracts",
        "unmapped_members",
        "unmapped_packages",
        "deterministic_risks",
        "deterministic_errors"
      ],
      "properties": {
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageFact"
          }
        },
        "affected_components": {
          "$ref": "#/$defs/strings"
        },
        "affected_capabilities": {
          "$ref": "#/$defs/strings"
        },
        "affected_contracts": {
          "$ref": "#/$defs/strings"
        },
        "unmapped_members": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unmappedMember"
          }
        },
        "unmapped_packages": {
          "$ref": "#/$defs/strings"
        },
        "deterministic_risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deterministicRisk"
          }
        },
        "deterministic_errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "code",
              "sha256"
            ],
            "properties": {
              "code": {
                "const": "deterministic_impact_error"
              },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "packageFact": {
      "type": "object",
      "required": [
        "name",
        "current_version",
        "target_version",
        "status",
        "changed_metadata_fields",
        "risk_findings",
        "archive_diff"
      ],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "target_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "changed_metadata_fields": {
          "$ref": "#/$defs/strings"
        },
        "risk_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "severity"
            ],
            "properties": {
              "kind": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "severity": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "archive_diff": {
          "type": "object",
          "properties": {
            "added": {
              "$ref": "#/$defs/archiveChange"
            },
            "changed": {
              "$ref": "#/$defs/archiveChange"
            },
            "removed": {
              "$ref": "#/$defs/archiveChange"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "archiveChange": {
      "type": "object",
      "required": [
        "count",
        "members",
        "truncated"
      ],
      "properties": {
        "count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "members": {
          "$ref": "#/$defs/strings"
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "unmappedMember": {
      "type": "object",
      "required": [
        "package",
        "change",
        "member"
      ],
      "properties": {
        "package": {
          "type": "string",
          "minLength": 1
        },
        "change": {
          "enum": [
            "added",
            "changed",
            "removed"
          ]
        },
        "member": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "deterministicRisk": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "count"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "required": [
        "max_hypotheses",
        "max_suggested_checks",
        "max_residual_risks",
        "max_review_requests",
        "max_evidence_refs_per_item",
        "raw_package_prose_allowed"
      ],
      "properties": {
        "max_hypotheses": {
          "const": 24
        },
        "max_suggested_checks": {
          "const": 24
        },
        "max_residual_risks": {
          "const": 24
        },
        "max_review_requests": {
          "const": 12
        },
        "max_evidence_refs_per_item": {
          "const": 8
        },
        "raw_package_prose_allowed": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
