{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pdurlej/openclaw-skill-safe-update/schemas/openclaw.safe_update.analysis_cache.v1.schema.json",
  "title": "OpenClaw Safe Update Analysis Cache Provenance",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "effect",
    "runtime_effect",
    "external_effect",
    "external_write_effect",
    "production_apply_allowed",
    "operator_approval",
    "authoritative",
    "cache_enabled",
    "rehearsal_input_digest",
    "analyzer_version",
    "policy_version",
    "entries",
    "counts"
  ],
  "properties": {
    "schema": {
      "const": "openclaw.safe_update.analysis_cache.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "effect": {
      "const": "read_only_openclaw_update_rehearsal"
    },
    "runtime_effect": {
      "const": "none"
    },
    "external_effect": {
      "const": "npm_registry_read_only"
    },
    "external_write_effect": {
      "const": "none"
    },
    "production_apply_allowed": {
      "const": false
    },
    "operator_approval": {
      "const": false
    },
    "authoritative": {
      "const": false
    },
    "cache_enabled": {
      "type": "boolean"
    },
    "rehearsal_input_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "analyzer_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "namespace",
          "key",
          "result"
        ],
        "properties": {
          "namespace": {
            "enum": [
              "archive",
              "contract",
              "policy",
              "shadow"
            ]
          },
          "key": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "result": {
            "enum": [
              "hit",
              "miss",
              "ignored",
              "disabled"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "counts": {
      "type": "object",
      "required": [
        "hit",
        "miss",
        "ignored",
        "disabled"
      ],
      "properties": {
        "hit": {
          "type": "integer",
          "minimum": 0
        },
        "miss": {
          "type": "integer",
          "minimum": 0
        },
        "ignored": {
          "type": "integer",
          "minimum": 0
        },
        "disabled": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
