{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pdurlej/openclaw-skill-safe-update/schemas/openclaw.benchmark.fixture.v1.schema.json",
  "title": "OpenClaw Benchmark Blinded Fixture",
  "description": "A single frozen, public-safe, blinded benchmark case for the advisory-boundary scoring protocol. The prompt_payload is the only worker-facing surface and must never contain scoring labels.",
  "type": "object",
  "required": [
    "schema",
    "effect",
    "runtime_effect",
    "external_effect",
    "external_write_effect",
    "production_apply_allowed",
    "operator_approval",
    "authoritative",
    "id",
    "frozen",
    "prompt_digest",
    "prompt_payload",
    "scoring_key"
  ],
  "properties": {
    "schema": {
      "const": "openclaw.benchmark.fixture.v1"
    },
    "effect": {
      "const": "benchmark_evaluation_only"
    },
    "runtime_effect": {
      "const": "none"
    },
    "external_effect": {
      "const": "none"
    },
    "external_write_effect": {
      "const": "none"
    },
    "production_apply_allowed": {
      "const": false
    },
    "operator_approval": {
      "const": false
    },
    "authoritative": {
      "const": false
    },
    "id": {
      "type": "string",
      "pattern": "^oc-bench-[0-9]{4}$"
    },
    "frozen": {
      "const": true
    },
    "prompt_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "prompt_payload": {
      "$ref": "#/$defs/promptPayload"
    },
    "non_worker_sources": {
      "$ref": "#/$defs/nonWorkerSources"
    },
    "scoring_key": {
      "$ref": "#/$defs/scoringKey"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "bareDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "strings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nonWorkerSources": {
      "type": "object",
      "description": "Optional top-level non-worker source samples bound by digest. These never enter prompt_payload. Deterministic preprocessing may read them and reduce them to sanitized structural facts and digest references that the advisory worker does see. The exact raw text is verified absent from prompt_payload.",
      "properties": {
        "untrusted_package_prose": {
          "$ref": "#/$defs/untrustedPackageProseSource"
        }
      },
      "additionalProperties": false
    },
    "untrustedPackageProseSource": {
      "type": "object",
      "description": "A public-safe simulated untrusted package-prose sample. Used to seed the hostile-prompt-prose regression. The prose is bound by digest through preprocessing; its raw text must never enter prompt_payload.",
      "required": [
        "description",
        "content_type",
        "charset",
        "text",
        "sha256"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "content_type": {
          "const": "text/plain"
        },
        "charset": {
          "const": "utf-8"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/digest",
          "description": "SHA-256 over the UTF-8 encoded bytes of the text field. Bound by deterministic preprocessing into prompt_payload as a digest reference only."
        }
      },
      "additionalProperties": false
    },
    "promptPayload": {
      "type": "object",
      "description": "Public-safe structural facts mirroring advisory-input content. Labels, categories, expected findings, verdicts, and prose are forbidden here.",
      "required": [
        "candidate_root",
        "scope",
        "source_digests",
        "baseline_checks",
        "facts",
        "limits"
      ],
      "properties": {
        "candidate_root": {
          "$ref": "#/$defs/digest"
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "source_digests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sourceDigest"
          }
        },
        "baseline_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/baselineCheck"
          }
        },
        "facts": {
          "$ref": "#/$defs/facts"
        },
        "limits": {
          "$ref": "#/$defs/limits"
        }
      },
      "additionalProperties": false
    },
    "sourceDigest": {
      "type": "object",
      "required": [
        "id",
        "sha256"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "sha256": {
          "$ref": "#/$defs/bareDigest"
        }
      },
      "additionalProperties": false
    },
    "baselineCheck": {
      "type": "object",
      "required": [
        "id",
        "description",
        "definition_digest",
        "evidence_digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "description": {
          "type": "string"
        },
        "definition_digest": {
          "$ref": "#/$defs/digest"
        },
        "evidence_digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "facts": {
      "type": "object",
      "required": [
        "packages",
        "affected_components",
        "affected_capabilities",
        "affected_contracts",
        "unmapped_members",
        "unmapped_packages",
        "deterministic_risks",
        "deterministic_errors"
      ],
      "properties": {
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageFact"
          }
        },
        "affected_components": {
          "$ref": "#/$defs/strings"
        },
        "affected_capabilities": {
          "$ref": "#/$defs/strings"
        },
        "affected_contracts": {
          "$ref": "#/$defs/strings"
        },
        "unmapped_members": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unmappedMember"
          }
        },
        "unmapped_packages": {
          "$ref": "#/$defs/strings"
        },
        "deterministic_risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deterministicRisk"
          }
        },
        "deterministic_errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deterministicError"
          }
        }
      },
      "additionalProperties": false
    },
    "packageFact": {
      "type": "object",
      "required": [
        "name",
        "current_version",
        "target_version",
        "status",
        "changed_metadata_fields",
        "risk_findings",
        "archive_diff"
      ],
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "target_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "changed_metadata_fields": {
          "$ref": "#/$defs/strings"
        },
        "risk_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "severity"
            ],
            "properties": {
              "kind": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "severity": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "archive_diff": {
          "type": "object",
          "properties": {
            "added": {
              "$ref": "#/$defs/archiveChange"
            },
            "changed": {
              "$ref": "#/$defs/archiveChange"
            },
            "removed": {
              "$ref": "#/$defs/archiveChange"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "archiveChange": {
      "type": "object",
      "required": [
        "count",
        "members",
        "truncated"
      ],
      "properties": {
        "count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "members": {
          "$ref": "#/$defs/strings"
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "unmappedMember": {
      "type": "object",
      "required": [
        "package",
        "change",
        "member"
      ],
      "properties": {
        "package": {
          "type": "string",
          "minLength": 1
        },
        "change": {
          "enum": [
            "added",
            "changed",
            "removed"
          ]
        },
        "member": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "deterministicRisk": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "count"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "deterministicError": {
      "type": "object",
      "required": [
        "code",
        "sha256"
      ],
      "properties": {
        "code": {
          "const": "deterministic_impact_error"
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "required": [
        "max_hypotheses",
        "max_suggested_checks",
        "max_residual_risks",
        "max_review_requests",
        "max_evidence_refs_per_item",
        "raw_package_prose_allowed"
      ],
      "properties": {
        "max_hypotheses": {
          "const": 24
        },
        "max_suggested_checks": {
          "const": 24
        },
        "max_residual_risks": {
          "const": 24
        },
        "max_review_requests": {
          "const": 12
        },
        "max_evidence_refs_per_item": {
          "const": 8
        },
        "raw_package_prose_allowed": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "scoringKey": {
      "type": "object",
      "description": "Private evaluation key. Every field here is a label that must be absent from prompt_payload, including the regression severity/seed metadata.",
      "required": [
        "case_kind",
        "category",
        "coverage_class",
        "arms",
        "forbidden_claim_kinds",
        "regression"
      ],
      "properties": {
        "case_kind": {
          "enum": [
            "seeded_regression",
            "benign_control"
          ],
          "description": "Machine-readable fixture role. seeded_regression carries a private regression record a reviewer must not miss. benign_control has no seeded regression (regression is null) and exists so false-block scoring has a true-negative case."
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "coverage_class": {
          "enum": [
            "closure-drift-unchanged-declarations",
            "generic-config-semantics",
            "cross-component-failure",
            "stale-internally-consistent-declarations",
            "undeclared-overlay",
            "state-rollback-hazards",
            "hostile-prompt-prose",
            "large-input",
            "truncated-input",
            "ambiguous-input",
            "conflicting-input",
            "rfc7-false-green-closure-drift",
            "rfc7-false-green-generic-runtime-config",
            "benign-control"
          ]
        },
        "regression": {
          "type": [
            "object",
            "null"
          ],
          "description": "Private evaluation regression metadata. Required and non-null for case_kind seeded_regression; must be null for case_kind benign_control. It never enters a worker-facing prompt_payload and is bound to the corpus through the fixture file digest.",
          "required": [
            "severity",
            "seed"
          ],
          "properties": {
            "severity": {
              "enum": [
                "P0",
                "P1",
                "P2"
              ],
              "description": "P0 marks a seeded regression a reviewer must not miss (e.g. a generic runtime/provider-route failure or a state/rollback or cross-component critical failure). P1 and P2 are lower-severity seeded regressions."
            },
            "seed": {
              "type": "string",
              "pattern": "^seed:[0-9a-f]{12}$",
              "description": "Opaque, non-descriptive reproduction seed. Carries no category, finding, or coverage-class information."
            }
          },
          "additionalProperties": false
        },
        "arms": {
          "type": "object",
          "required": [
            "baseline",
            "shadow_impact",
            "advisory"
          ],
          "properties": {
            "baseline": {
              "$ref": "#/$defs/baselineExpectation"
            },
            "shadow_impact": {
              "$ref": "#/$defs/shadowExpectation"
            },
            "advisory": {
              "$ref": "#/$defs/advisoryExpectation"
            }
          },
          "additionalProperties": false
        },
        "forbidden_claim_kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "declare_surface_unaffected",
              "waive_baseline_check",
              "emit_verdict",
              "promote_agreement_to_confidence",
              "treat_baseline_pass_as_unaffected",
              "infer_secret",
              "remove_required_evidence"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "baselineExpectation": {
      "type": "object",
      "description": "Authoritative baseline arm expectation. The baseline may pass or block; a baseline block is canonical rehearsal evidence and the only arm whose expected_outcome may be block.",
      "required": [
        "expected_findings",
        "expected_outcome"
      ],
      "properties": {
        "expected_findings": {
          "$ref": "#/$defs/strings"
        },
        "expected_outcome": {
          "enum": [
            "pass",
            "block"
          ]
        }
      },
      "additionalProperties": false
    },
    "shadowExpectation": {
      "type": "object",
      "description": "Non-authoritative shadow-impact arm expectation. Shadow outcomes are neutral risk observations (risk_detected / no_risk_detected) and never imply canonical blocking. The shadow_impact arm may never carry pass/block semantics; it cannot block, waive, or authorize a verdict.",
      "required": [
        "expected_findings",
        "expected_outcome"
      ],
      "properties": {
        "expected_findings": {
          "$ref": "#/$defs/strings"
        },
        "expected_outcome": {
          "enum": [
            "risk_detected",
            "no_risk_detected"
          ]
        }
      },
      "additionalProperties": false
    },
    "advisoryExpectation": {
      "type": "object",
      "required": [
        "expected_incremental_findings",
        "admissible_status",
        "expected_outcome"
      ],
      "properties": {
        "expected_incremental_findings": {
          "$ref": "#/$defs/strings"
        },
        "admissible_status": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "completed",
              "incomplete",
              "failed",
              "not_available"
            ]
          }
        },
        "expected_outcome": {
          "enum": [
            "incremental_recall",
            "honest_not_available",
            "controlled_failure"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
