{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pdurlej/openclaw-skill-safe-update/schemas/openclaw.safe_update.installation_candidate_lock.v1.schema.json",
  "title": "OpenClaw Composed Installation Candidate Lock",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "effect",
    "runtime_effect",
    "external_effect",
    "external_write_effect",
    "production_apply_allowed",
    "operator_approval",
    "status",
    "current_root",
    "target_root",
    "current",
    "target",
    "errors"
  ],
  "properties": {
    "schema": {
      "const": "openclaw.safe_update.installation_candidate_lock.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "effect": {
      "const": "read_only_openclaw_update_rehearsal"
    },
    "runtime_effect": {
      "const": "none"
    },
    "external_effect": {
      "const": "npm_registry_read_only"
    },
    "external_write_effect": {
      "const": "none"
    },
    "production_apply_allowed": {
      "const": false
    },
    "operator_approval": {
      "const": false
    },
    "status": {
      "enum": [
        "success",
        "failed"
      ]
    },
    "current_root": {
      "$ref": "#/$defs/nullableDigest"
    },
    "target_root": {
      "$ref": "#/$defs/nullableDigest"
    },
    "current": {
      "oneOf": [
        {
          "$ref": "#/$defs/candidate"
        },
        {
          "type": "null"
        }
      ]
    },
    "target": {
      "oneOf": [
        {
          "$ref": "#/$defs/candidate"
        },
        {
          "type": "null"
        }
      ]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "nullableDigest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "environment": {
      "type": "object",
      "required": [
        "node_version",
        "npm_version",
        "os",
        "arch",
        "libc"
      ],
      "properties": {
        "node_version": {
          "type": "string",
          "minLength": 1
        },
        "npm_version": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "type": "string",
          "minLength": 1
        },
        "libc": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": [
        "kind",
        "ref",
        "identity",
        "integrity"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "identity": {
          "type": "string",
          "minLength": 1
        },
        "integrity": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "contract": {
      "type": "object",
      "required": [
        "id",
        "digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "dependency": {
      "type": "object",
      "required": [
        "component_id",
        "kind"
      ],
      "properties": {
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "component": {
      "type": "object",
      "required": [
        "id",
        "roles",
        "application_phases",
        "artifacts",
        "contracts",
        "depends_on",
        "supports",
        "governance_digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "application_phases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "contracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contract"
          }
        },
        "depends_on": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependency"
          }
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "governance_digest": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": [
        "schema",
        "lane",
        "core_root",
        "installation_contract_digest",
        "composition_policy_version",
        "analyzer_version",
        "environment",
        "components",
        "root"
      ],
      "properties": {
        "schema": {
          "const": "openclaw.safe_update.installation_candidate.v1"
        },
        "lane": {
          "enum": [
            "current",
            "target"
          ]
        },
        "core_root": {
          "$ref": "#/$defs/digest"
        },
        "installation_contract_digest": {
          "$ref": "#/$defs/digest"
        },
        "composition_policy_version": {
          "type": "string",
          "minLength": 1
        },
        "analyzer_version": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component"
          }
        },
        "root": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
